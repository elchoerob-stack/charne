function WLScreen({wl,onWatch,onSelect,nav,onRevoke}){
  const saved=PROPS.filter(p=>wl.includes(p.id));
  return(
    <div style={{paddingBottom:72}}>
      <div style={{background:C.nav,padding:"36px 14px 18px"}}>
        <h2 style={{color:"#fff",fontSize:20,fontWeight:700,marginBottom:2}}>My Watchlist</h2>
        <p style={{color:"rgba(255,255,255,.4)",fontSize:12}}>{saved.length} saved {saved.length===1?"property":"properties"}</p>
      </div>
      <div style={{padding:"14px 14px 0"}}>
        {saved.length===0?(
          <div style={{textAlign:"center",padding:"48px 18px"}}>
            <Heart size={38} color={C.border}/>
            <h3 style={{color:C.text,marginTop:12,marginBottom:7,fontSize:16}}>No saved properties yet</h3>
            <p style={{color:C.muted,marginBottom:18,fontSize:14}}>Tap the heart on any property to save it here.</p>
            <button onClick={()=>nav("properties")} style={{background:C.nav,border:"none",borderRadius:8,padding:"11px 22px",color:"#fff",fontWeight:600,fontSize:14,cursor:"pointer"}}>Browse Properties</button>
          </div>
        ):saved.map(p=><PropCard key={p.id} p={p} watched onWatch={onWatch} onSelect={onSelect}/>)}
      </div>
      <div style={{margin:"6px 14px 22px",background:C.bg,border:`1px solid ${C.border}`,borderRadius:12,padding:"13px 15px"}}>
        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:6}}><Shield size={12} color={C.muted}/><span style={{color:C.muted,fontSize:10,fontWeight:700,textTransform:"uppercase",letterSpacing:1.2}}>Your POPIA Rights</span></div>
        <p style={{color:C.muted,fontSize:12,lineHeight:1.55,marginBottom:9}}>Your watchlist is stored only on this device. Charné Snyman is the data controller. You may withdraw consent and delete all data at any time.</p>
        <button onClick={()=>{if(window.confirm("Delete your watchlist and consent record?"))onRevoke();}}
          style={{display:"flex",alignItems:"center",gap:6,background:"none",border:"1px solid #DC2626",borderRadius:7,padding:"7px 11px",color:"#DC2626",fontSize:12,fontWeight:600,cursor:"pointer"}}>
          <Trash2 size={12}/> Withdraw Consent & Delete My Data
