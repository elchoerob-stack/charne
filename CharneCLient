}

function NavBar({screen,nav,wlCount}){
  const tabs=[{id:"home",label:"Home",icon:Home},{id:"properties",label:"Properties",icon:Building2},{id:"watchlist",label:"Watchlist",icon:Bookmark,badge:wlCount}];
  return(
    <div style={{position:"fixed",bottom:0,left:0,right:0,background:C.surface,borderTop:`1px solid ${C.border}`,display:"flex",zIndex:50}}>
      {tabs.map(({id,label,icon:Icon,badge})=>(
        <button key={id} onClick={()=>nav(id)} style={{flex:1,padding:"10px 6px 8px",background:"none",border:"none",cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",gap:3,position:"relative"}}>
          <div style={{position:"relative"}}>
            <Icon size={20} color={screen===id?C.nav:C.muted} fill={screen===id?"rgba(15,32,64,.1)":"none"}/>
            {badge>0&&<span style={{position:"absolute",top:-4,right:-6,background:C.gold,color:"#fff",borderRadius:"50%",width:14,height:14,fontSize:9,fontWeight:700,display:"flex",alignItems:"center",justifyContent:"center"}}>{badge}</span>}
          </div>
          <span style={{fontSize:10,fontWeight:600,color:screen===id?C.nav:C.muted}}>{label}</span>
          {screen===id&&<div style={{position:"absolute",top:0,left:"25%",right:"25%",height:2,background:C.nav,borderRadius:"0 0 2px 2px"}}/>}
        </button>
      ))}
    </div>
  );
}

export default function App(){
  const [loading,setLoading]=useState(true);
  const [consent,setConsent]=useState(null);
  const [screen,setScreen]=useState("home");
  const [sel,setSel]=useState(null);
  const [wl,setWl]=useState([]);

  useEffect(()=>{
    (async()=>{
      const c=await POPIA.getConsent();
      const w=await POPIA.getWL();
      setConsent(c); setWl(w); setLoading(false);
    })();
  },[]);

  const handleConsent=async(granted)=>setConsent(await POPIA.record(granted));
  const handleRevoke=async()=>{await POPIA.revoke();setConsent(null);setWl([]);setScreen("home");};
  const toggleWl=async(id)=>{const u=wl.includes(id)?wl.filter(i=>i!==id):[...wl,id];setWl(u);await POPIA.saveWL(u);};
  const nav=(s)=>{setSel(null);setScreen(s);};

  if(loading)return<div style={{display:"flex",alignItems:"center",justifyContent:"center",height:"100vh",background:"#0F2040"}}><div style={{textAlign:"center"}}><div style={{width:36,height:36,border:"3px solid rgba(196,154,47,.3)",borderTop:"3px solid #C49A2F",borderRadius:"50%",animation:"spin 0.8s linear infinite",margin:"0 auto 10px"}}/><p style={{color:"rgba(255,255,255,.4)",fontSize:13}}>Loading…</p><style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style></div></div>;
  if(!consent)return<POPIAGate onDecide={handleConsent}/>;
  if(consent&&!consent.granted)return<div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",height:"100vh",padding:32,textAlign:"center",background:C.bg}}><div style={{width:52,height:52,borderRadius:"50%",background:"#FEE2E2",display:"flex",alignItems:"center",justifyContent:"center",marginBottom:14}}><X size={22} color="#DC2626"/></div><h2 style={{color:C.text,marginBottom:8}}>Access Not Available</h2><p style={{color:C.muted,maxWidth:280,lineHeight:1.6,marginBottom:22}}>Charné needs your consent under POPIA. No data is collected without your agreement.</p><button onClick={()=>setConsent(null)} style={{padding:"12px 24px",background:C.nav,border:"none",borderRadius:8,color:"#fff",fontWeight:600,cursor:"pointer"}}>Review Privacy Notice</button></div>;

  return(
    <div style={{background:C.bg,minHeight:"100vh",fontFamily:"-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif",maxWidth:480,margin:"0 auto"}}>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
      {sel?<PropDetail p={sel} watched={wl.includes(sel.id)} onWatch={toggleWl} onBack={()=>setSel(null)}/>:<>
        {screen==="home"&&<HomeScreen nav={nav} onSelect={setSel} wl={wl} onWatch={toggleWl}/>}
        {screen==="properties"&&<PropsScreen onSelect={setSel} wl={wl} onWatch={toggleWl}/>}
        {screen==="watchlist"&&<WLScreen wl={wl} onWatch={toggleWl} onSelect={setSel} nav={nav} onRevoke={handleRevoke}/>}
        <NavBar screen={screen} nav={nav} wlCount={wl.length}/>
      </>}
    </div>
  );
}
